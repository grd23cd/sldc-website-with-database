---
import type { ImageMetadata } from 'astro';

import img1 from '../assets/carousel/treeplanting-1.jpg';
import img2 from '../assets/carousel/treeplanting-2.jpg';
import img3 from '../assets/carousel/treeplanting-3.jpg';
import img4 from '../assets/carousel/treeplanting-4.jpg';
import img5 from '../assets/carousel/treeplanting-5.jpg';

const images: ImageMetadata[] = [img1, img2, img3, img4, img5];
---

<div class="marquee">
  <ul class="marquee-content">
    {/* @ts-ignore */}
    {images.map((img, i) => (
      <li>
        <img src={img.src} alt={`Tree planting ${i + 1}`} />
      </li>
    ))}
  </ul>
</div>

<style>
  :root {
    --marquee-elements-displayed: 3;
    --marquee-element-width: calc(100vw / var(--marquee-elements-displayed));
    --marquee-element-height: calc(var(--marquee-element-width) * 9 / 16);
    --marquee-animation-duration: calc(var(--marquee-elements) * 3s);
  }

  .marquee {
    width: 100vw;
    height: var(--marquee-element-height);
    overflow: hidden;
    position: relative;
  }

  .marquee-content {
    list-style: none;
    margin: 0;
    padding: 0;
    height: 100%;
    display: flex;
    animation: marquee-scroll var(--marquee-animation-duration) linear infinite;
  }

  .marquee-content li {
    flex-shrink: 0;
    width: var(--marquee-element-width);
    height: 100%;
    padding: 0 0.5rem;
  }

  .marquee-content li img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.75rem;
    display: block;
  }

  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(calc(-1 * var(--marquee-element-width) * var(--marquee-elements))); }
  }

  @media (max-width: 768px) {
    :root { --marquee-elements-displayed: 2; }
  }

  @media (max-width: 480px) {
    :root { --marquee-elements-displayed: 1; }
  }
</style>

<script>
  // @ts-nocheck
  const root = document.documentElement;
  const displayed = parseInt(
    getComputedStyle(root).getPropertyValue('--marquee-elements-displayed')
  );
  const list = document.querySelector<HTMLUListElement>('ul.marquee-content')!;
  const count = list.children.length;

  // Set the element count CSS var so the animation distance is exact
  root.style.setProperty('--marquee-elements', String(count));

  // Clone only enough to fill the visible window for seamless loop
  for (let i = 0; i < displayed; i++) {
    list.appendChild(list.children[i].cloneNode(true));
  }
</script>