---
const base = import.meta.env.BASE_URL;
const membershipLink = `${base}membership`;
---

<!-- FLOATING BUTTON (DESKTOP ONLY) -->
<div class="hidden md:flex fixed bottom-6 right-6 flex-col items-end z-50 group">

  <!-- HOVER TEXT (TOOLTIP) -->
  <div class="mb-3 px-3 py-1 bg-black/80 text-white text-[1.125rem] rounded-md 
              opacity-0 group-hover:opacity-100 transition duration-200">
    FAQ
  </div>

  <!-- CHAT BUTTON -->
  <button
    id="chatToggle"
    class="bg-green-700 hover:bg-green-800 text-white w-14 h-14 rounded-full 
           flex items-center justify-center text-2xl shadow-lg"
  >
    💬
  </button>
</div>

<!-- CHAT WINDOW (DESKTOP ONLY) -->
<div
  id="chatWidget"
  class="hidden md:fixed md:bottom-24 md:right-6 md:w-80 md:h-[420px]
         w-full h-[85vh]
         bg-white shadow-2xl border 
         flex flex-col z-50
         rounded-t-xl sm:rounded-xl overflow-hidden"
>
  <!-- HEADER -->
  <div class="bg-green-700 text-white px-4 py-3 flex justify-between items-center">
    <span class="font-semibold">FAQ</span>
    <button id="closeChat">✕</button>
  </div>

  <!-- QUICK QUESTIONS -->
  <div
    id="quickQuestions"
    class="p-2 border-b flex flex-wrap gap-2 text-xs"
  ></div>

  <!-- CHAT AREA -->
  <div
    id="chatBox"
    class="flex-1 overflow-y-auto space-y-2 text-sm p-2"
  ></div>
</div>

<style>
  .msg {
    opacity: 0;
    transform: translateY(8px);
    animation: fadeInUp 0.25s ease forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script define:vars={{ membershipLink }}>
  const QA = {
    "What are your hours": "We are open 8AM–5PM Monday to Friday.",

    "Where are you located":
      "We are located in General Lucban corner Emilio Jacinto St. Lucban, Quezon.",

    "How to join":
      `Visit our membership page. <a href="${membershipLink}" class="text-blue-600 underline font-medium">Click here</a>.`,

    "Kailan ang interview": "Tuwing Tuesday at Friday, 11:30 AM",
    "Kailan ang approval": "Pagkatapos ng interview tuwing Tuesday at Friday",
    "Sino o ilan ang co maker": "Kahit ilan ang co maker basta't may sapat na kita at tama sa utang",
  };

  const chatBox = document.getElementById("chatBox");
  const chatWidget = document.getElementById("chatWidget");
  const chatToggle = document.getElementById("chatToggle");
  const closeChat = document.getElementById("closeChat");
  const quickContainer = document.getElementById("quickQuestions");

  let welcomeShown = false;

  function clearChat() {
    chatBox.innerHTML = "";
    welcomeShown = false;
  }

  function addMessage(text, type) {
    const div = document.createElement("div");

    div.className =
      type === "user"
        ? "text-right text-green-700 msg"
        : "text-left text-gray-700 msg";

    if (type === "bot") {
      div.innerHTML = text;
    } else {
      div.textContent = text;
    }

    chatBox.appendChild(div);
    chatBox.scrollTop = chatBox.scrollHeight;
  }

  function showWelcome() {
    if (welcomeShown) return;

    welcomeShown = true;

    setTimeout(() => {
      addMessage("Hi 👋 How can I help you today?", "bot");
    }, 300);
  }

  function normalize(text) {
    return text
      .toLowerCase()
      .replace(/[^\w\s]/g, "")
      .replace(/\s+/g, " ")
      .trim();
  }

  function getAnswer(msg) {
    const userMsg = normalize(msg);

    for (const key in QA) {
      const qKey = normalize(key);

      if (userMsg.includes(qKey)) {
        return QA[key];
      }
    }

    return "Sorry, I don't understand that.";
  }

  function sendMessage(msg) {
    if (!msg) return;

    addMessage(msg, "user");
    addMessage(getAnswer(msg), "bot");
  }

  function loadQuickQuestions() {
    quickContainer.innerHTML = "";

    Object.keys(QA).forEach((key) => {
      const btn = document.createElement("button");

      btn.className =
        "quick-btn bg-gray-100 hover:bg-gray-200 px-2 py-1 rounded-md";

      btn.textContent = key;

      btn.addEventListener("click", () => {
        sendMessage(key);
      });

      quickContainer.appendChild(btn);
    });
  }

  chatToggle.addEventListener("click", () => {
    const isHidden = chatWidget.classList.contains("hidden");

    chatWidget.classList.toggle("hidden");

    if (isHidden) {
      clearChat();
      showWelcome();
      loadQuickQuestions();
    }
  });

  closeChat.addEventListener("click", () => {
    chatWidget.classList.add("hidden");
    clearChat();
  });
</script>