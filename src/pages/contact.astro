---
import BaseLayout from "../layouts/BaseLayout.astro";
import Mart1Location from "../components/Mart1-Location.astro";
import Mart2Location from "../components/Mart2-Location.astro";
import Mart3Location from "../components/Mart3-Location.astro";
import Mart4Location from "../components/Mart4-Location.astro";
import RicemillLocation from "../components/Ricemill-Location.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 space-y-12 overflow-x-hidden">

    <!-- HEADER -->
    <section class="text-center space-y-4">
      <h1 class="text-5xl font-bold tracking-tight text-slate-900">
        Contact Us
      </h1>
      <p class="text-slate-500">
        Get in touch with San Luis Development Cooperative
      </p>

      <!-- ISSUE SUBMIT CARD -->
      <div class="mt-6">
        <a
          href={`${base}submitissue`}
          class="inline-block bg-green-900 text-white px-6 py-3 rounded-xl shadow-md hover:bg-green-800 transition"
        >
          Have an issue? Submit here
        </a>
      </div>
    </section>

    <!-- CONTACT CARDS -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- MAIN CONTACT -->
      <div class="bg-white rounded-2xl shadow-md hover:shadow-lg transition p-6 space-y-3 min-w-0 break-words">
        <h2 class="text-lg font-semibold text-slate-900">Contact Number</h2>
        <p class="text-slate-700 break-words">
          0917-125-1967
        </p>
      </div>

      <!-- CREDIT DEPT -->
      <div class="bg-white rounded-2xl shadow-md hover:shadow-lg transition p-6 space-y-3 min-w-0 break-words">
        <h2 class="text-lg font-semibold text-slate-900">Credit Department</h2>
        <p class="text-slate-700 break-words">
          540-4910 / 0933-037-1708
        </p>
      </div>

      <!-- GROCERY STORE -->
      <div class="bg-white rounded-2xl shadow-md hover:shadow-lg transition p-6 space-y-3 md:col-span-2 min-w-0 break-words">
        <h2 class="text-lg font-semibold text-slate-900">Grocery Store (Marts)</h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-slate-700 break-words">
          <p>Mart 1: 540-4610</p>
          <p>Mart 2: 540-6688</p>
          <p>Mart 3: 540-5630</p>
        </div>
      </div>

      <!-- RICE MILL -->
      <div class="bg-white rounded-2xl shadow-md hover:shadow-lg transition p-6 space-y-3 min-w-0 break-words">
        <h2 class="text-lg font-semibold text-slate-900">Ricemill</h2>
        <p class="text-slate-700 break-words">
          540-4201 / 0970-781-9657
        </p>
      </div>

      <!-- WATER STATION -->
      <div class="bg-white rounded-2xl shadow-md hover:shadow-lg transition p-6 space-y-3 min-w-0 break-words">
        <h2 class="text-lg font-semibold text-slate-900">Water Filling Station</h2>
        <p class="text-slate-700 break-words">
          0956-411-5441 / 0929-705-1314
        </p>
      </div>

      <!-- EMAIL -->
      <div class="bg-white rounded-2xl shadow-md hover:shadow-lg transition p-6 space-y-3 md:col-span-2 min-w-0">
        <h2 class="text-lg font-semibold text-slate-900">Email Address</h2>
        <p class="text-slate-700 break-all">
          sanluisdevelopmentcooperative@yahoo.com
        </p>
      </div>

      <!-- GCASH -->
      <div class="bg-white rounded-2xl shadow-md hover:shadow-lg transition p-6 space-y-3 md:col-span-2 min-w-0 break-words">
        <h2 class="text-lg font-semibold text-slate-900">GCash</h2>
        <p class="text-slate-700 break-words">
          0916-376-5844 (A** M**** B.)
        </p>
        <p class="text-slate-700 break-words">
          0956-928-2395 (L****B*****B.)
        </p>
      </div>

      <!-- ADDRESS -->
      <div class="bg-white rounded-2xl shadow-md hover:shadow-lg transition p-6 space-y-3 md:col-span-2 min-w-0 break-words">
        <h2 class="text-lg font-semibold text-slate-900">Visit Us</h2>
        <p class="text-slate-700 break-words">
          General Lucban corner Emilio Jacinto St. Lucban, Quezon
        </p>
      </div>

    </section>

    <!-- MAP SECTION -->
    <section class="bg-green-900 text-white rounded-2xl shadow-lg overflow-hidden text-center">
      <div class="p-6">
        <h2 class="text-3xl font-bold">Our Location</h2>
        <p class="text-white/80 mt-2">Find us on the map below</p>
      </div>

      <h2 class="text-xl font-bold p-5">MART 2 - MAIN</h2>
      <div class="p-4 md:p-6">
        <Mart2Location />
      </div>

      <h2 class="text-xl font-bold p-5">MART 1</h2>
      <div class="p-4 md:p-6">
        <Mart1Location />
      </div>

      <h2 class="text-xl font-bold p-5">MART 3</h2>
      <div class="p-4 md:p-6">
        <Mart3Location />
      </div>

      <h2 class="text-xl font-bold p-5">MART 4 - LUISIANA</h2>
      <div class="p-4 md:p-6">
        <Mart4Location />
      </div>

      <h2 class="text-xl font-bold p-5">Water Refilling Station</h2>
      <div class="p-4 md:p-6">
        <Mart1Location />
      </div>

      <h2 class="text-xl font-bold p-5">Appliances and Gift Shop</h2>
      <div class="p-4 md:p-6">
        <Mart1Location />
      </div>

      <h2 class="text-xl font-bold p-5">Ricemill</h2>
      <div class="p-4 md:p-6">
        <RicemillLocation />
      </div>

    </section>

  </div>
</BaseLayout>
