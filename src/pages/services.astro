---
import BaseLayout from "../layouts/BaseLayout.astro";
import Accordion from "../components/Accordion.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }

  /* FIX NAVBAR OVERLAP (IMPORTANT) */
  [id] {
    scroll-margin-top: 120px;
  }
</style>

<div class="max-w-6xl mx-auto px-6 py-16 space-y-14">

  <!-- HEADER -->
  <section class="text-center space-y-4">
    <h1 class="text-5xl font-bold tracking-tight text-slate-900">
      Our Cooperative Services
    </h1>
    <p class="text-lg text-slate-600">
      Tuklasin at alamin ang iba't ibang produkto at serbisyo natin
    </p>
    <p class="text-slate-500">
      Halina't ating tangkilikin!
    </p>
  </section>

  <!-- ACCORDIONS -->
  <div class="space-y-6">

    <!-- LOANS -->
    <div id="loans" class="scroll-mt-32 bg-white rounded-2xl shadow-md hover:shadow-lg transition overflow-hidden">
      <Accordion title="Loans">
        <p><b>Regular Loan</b> - 3x deposit, 1–36 months</p>
        <p><b>Special Loan</b> - Emergency, petty cash</p>
        <p><b>Secured Loan</b> - up to ₱2,000,000</p>
        <p><b>Car Loan</b> - 3–5 years term</p>
      </Accordion>
    </div>

    <!-- SAVINGS -->
    <div id="savings" class="scroll-mt-32 bg-white rounded-2xl shadow-md hover:shadow-lg transition overflow-hidden">
      <Accordion title="Savings">
        <p>• Savings Deposit (₱500 minimum)</p>
        <p>• Withdraw anytime</p>
        <p>• Time Deposit (₱10,000 minimum)</p>
      </Accordion>
    </div>

    <!-- CONSUMER STORE -->
    <div id="store" class="scroll-mt-32 bg-white rounded-2xl shadow-md hover:shadow-lg transition overflow-hidden">
      <Accordion title="Consumer Store">
        <a class="block text-blue-600 hover:underline" href={`${base}mart1`}>SLDC Mart - I Lucban</a>
        <a class="block text-blue-600 hover:underline" href={`${base}mart2`}>SLDC Mart - II Lucban</a>
        <a class="block text-blue-600 hover:underline" href={`${base}mart3`}>SLDC Mart - III Lucban</a>
        <a class="block text-blue-600 hover:underline" href={`${base}mart4`}>SLDC Mart - IV Lucban</a>
        <a class="block text-blue-600 hover:underline" href={`${base}waterrefilling`}>Water Refilling Station</a>
        <a class="block text-blue-600 hover:underline" href={`${base}appliances`}>Appliances & Gift Shop</a>
      </Accordion>
    </div>

    <!-- PRODUCTION -->
    <div id="production" class="scroll-mt-32 bg-white rounded-2xl shadow-md hover:shadow-lg transition overflow-hidden">
      <Accordion title="Production & Marketing">
        <p>Palay</p>
        <p>Rice</p>
        <p>Rice bran and other by-products</p>
      </Accordion>
    </div>

    <!-- MEMBERS BENEFITS -->
    <div id="benefits" class="scroll-mt-32 bg-white rounded-2xl shadow-md hover:shadow-lg transition overflow-hidden">
      <Accordion title="Members Benefits">
        <p>• Abuluyan assistance</p>
        <p>• Loan protection</p>
        <p>• Insurance programs</p>
      </Accordion>
    </div>

    <!-- COMMUNITY SERVICES & ACTIVITIES-->
    <div id="community" class="scroll-mt-32 bg-white rounded-2xl shadow-md hover:shadow-lg transition overflow-hidden">
      <Accordion title="Community Services & Activities">
        <a class="block text-blue-600 hover:underline" href={`${base}dumagat`}>Dumagat Community Service</a>
        <a class="block text-blue-600 hover:underline" href={`${base}premembership`}>Pre-Membership Seminar Luisiana</a>
        <a class="block text-blue-600 hover:underline" href={`${base}tagcodec`}>TAGCODEC Ownership Seminar</a>
        <a class="block text-blue-600 hover:underline" href={`${base}treeplanting`}>Tree Planting Activity (Ricemill)</a>
        <a class="block text-blue-600 hover:underline" href={`${base}teambuilding2025`}>Team Building 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}trickortreat2025`}>Trick or Treat 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}visitaiglesia2025`}>Visita Iglesia 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}philippinechamberofcooperativesgeneralassembly2025`}>Philippine Chamber of Cooperatives General Assembly 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}processionfeastofsanrafaelarkanghel2025`}>Procession Feast of San Rafael Arkanghel 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}quezonfederationandunionofcooperatives2025`}>Quezon Federation and Union of Cooperatives 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}realoutreach2025`}>Real Outreach 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}sldcthanksgivingparty2025`}>SLDC Thanksgiving Party 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}coopmonth2025treeplanting`}>Coop Month 2025 Tree Planting</a>
        <a class="block text-blue-600 hover:underline" href={`${base}independenceday2025`}>Independence Day 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}massfeastofsanrafaelarkanghel2025`}>Mass Feast of San Rafael Arkangel 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}pahiyasgrandparade2025`}>Pahiyas Grand Parade 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}4kgeneralassembly2025`}>4K General Assembly 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}58thfoundinganniversarymass2025`}>58th Founding Anniversary Mass 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}58thfoundinganniversarymedicalmission2025`}>58th Founding Anniversary Medical Mission 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}bloodlettingactivity2025`}>Blood Letting Activity 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}cbqpgeneralassembly2025`}>CBQP General Assembly 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}christmasgivingpelnagsinamo2025`}>Christmas Giving PEL Nagsinamo 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}clean-updrivembrpcp2025`}>Clean Up Drive MBRPCP 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}2ndnationalleadershipcongress2025`}>2nd National Leadership Congress 2025</a>
        <a class="block text-blue-600 hover:underline" href={`${base}2ndquarternationwidesimultaneousearthquakedrill2025`}>2nd Quarter Nationwide Simultaneous Earthquake Drill 2025</a>
      </Accordion>
    </div>

    <!-- OTHER SERVICES -->
    <div id="others" class="scroll-mt-32 bg-white rounded-2xl shadow-md hover:shadow-lg transition overflow-hidden">
      <Accordion title="Other Services">
        <a class="block text-blue-600 hover:underline" href={`${base}palay`}>Palay Warehousing</a>
        <a class="block text-blue-600 hover:underline" href={`${base}ricemilling`}>Rice Milling</a>
        <a class="block text-blue-600 hover:underline" href={`${base}drying`}>Drying</a>
        <a class="block text-blue-600 hover:underline" href={`${base}hall`}>Function Hall/Chair Rental</a>
        <a class="block text-blue-600 hover:underline" href={`${base}van`}>Van for Hire</a>
        <a class="block text-blue-600 hover:underline" href={`${base}atm`}>ATM Services</a>
      </Accordion>
    </div>

  </div>
</div>

<script is:inline>
  function openAccordionFromHash() {
    const hash = window.location.hash;
    if (!hash) return;

    const target = document.querySelector(hash);
    if (!target) return;

    const accordion = target.querySelector("[data-accordion]");
    if (accordion) {
      accordion.open = true;
    }

    setTimeout(() => {
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }, 150);
  }

  document.addEventListener("DOMContentLoaded", openAccordionFromHash);
  window.addEventListener("hashchange", openAccordionFromHash);
</script>

</BaseLayout>
