---
import BaseLayout from "../layouts/BaseLayout.astro";
import Preview from "../components/Preview.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout>

<!-- HERO -->
<section
  id="home"
  class="relative flex items-center justify-center text-center min-h-[calc(100svh-4rem)] pt-24 pb-16 sm:pt-16 sm:pb-10"
  style={`background-image: url(${base}images/hero.jpg); background-size: cover; background-position: center;`}
>

  <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-black/80"></div>

  <div class="relative z-10 max-w-3xl px-6 text-white space-y-6">

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight">
      San Luis Development Cooperative
    </h1>

    <p class="text-yellow-300 font-semibold">Since 1967</p>

    <p class="text-white/80">
        San Luis Development Cooperative lagi mong maaasahan at handa kang tulungan sa iyong pangangailangan sa pananalapi at iba pang serbisyo. Halina't maging bahagi ng aming kooperatiba at sabay-sabay nating pagyamanin ang ating komunidad!  
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
      <a href={`${base}services`} class="bg-green-600 hover:bg-green-500 px-6 py-3 rounded-xl font-semibold">
        Explore Services
      </a>

      <a href={`${base}about`} class="border border-white/40 px-6 py-3 rounded-xl font-semibold">
        Learn More
      </a>
    </div>

  </div>
</section>

<!-- PREVIEW -->
<section id="preview" class="py-20 bg-slate-50">
      <Preview />
</section>

<!-- ABOUT PREVIEW -->
<section id="about" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6 text-center space-y-6">

    <h2 class="text-4xl font-bold">About Us</h2>

    <p class="text-slate-600 max-w-3xl mx-auto leading-relaxed">
      San Luis Development Cooperative is committed to providing financial services,
      empowering members, and building stronger communities in Lucban and nearby areas.
    </p>

    <a href={`${base}about`} class="inline-block text-blue-600 hover:underline">
      View Full About Page →
    </a>

  </div>
</section>

<!-- SERVICES PREVIEW -->
<section id="services" class="py-20 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6 space-y-10 text-center">

    <h2 class="text-4xl font-bold">Our Services</h2>

    <p class="text-slate-600 max-w-3xl mx-auto leading-relaxed">
      Click on each service category to learn more about how we can support your financial and community needs.
    </p>

    <div class="grid md:grid-cols-3 gap-6 text-left">

      <a href={`${base}services#loans`} class="block bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition">
        <h3 class="font-semibold text-xl mb-2">Loans</h3>
        <p class="text-slate-600 text-sm">Accessible loan programs designed to support members’ financial needs.</p>
      </a>

      <a href={`${base}services#savings`} class="block bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition">
        <h3 class="font-semibold text-xl mb-2">Savings</h3>
        <p class="text-slate-600 text-sm">Safe and reliable savings options that help members grow funds.</p>
      </a>

      <a href={`${base}services#store`} class="block bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition">
        <h3 class="font-semibold text-xl mb-2">Consumer Store</h3>
        <p class="text-slate-600 text-sm">Affordable essential goods for members.</p>
      </a>

      <a href={`${base}services#production`} class="block bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition">
        <h3 class="font-semibold text-xl mb-2">Production & Marketing</h3>
        <p class="text-slate-600 text-sm">Support for local business growth.</p>
      </a>

      <a href={`${base}services#benefits`} class="block bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition">
        <h3 class="font-semibold text-xl mb-2">Members Benefits</h3>
        <p class="text-slate-600 text-sm">Programs that improve member welfare.</p>
      </a>

      <a href={`${base}services#community`} class="block bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition">
        <h3 class="font-semibold text-xl mb-2">Community Services & Activities</h3>
        <p class="text-slate-600 text-sm">Activities and development programs.</p>
      </a>

      <a href={`${base}services#others`} class="block bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition">
        <h3 class="font-semibold text-xl mb-2">Other Services</h3>
        <p class="text-slate-600 text-sm">Additional services.</p>
      </a>

    </div>
  </div>
</section>

<!-- GALLERY (OPTIMIZED) -->
<section id="gallery" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6 text-center space-y-6">

    <h2 class="text-4xl font-bold">Our Gallery</h2>

    <p class="text-slate-600 max-w-3xl mx-auto">
      Take a look at our cooperative services and activities.
    </p>

    <a
      href={`${base}gallery`}
      class="inline-block mt-6 bg-green-700 hover:bg-green-600 text-white px-6 py-3 rounded-xl font-semibold"
    >
      Visit Our Gallery →
    </a>

  </div>
</section>

<!-- MEMBERSHIP CTA -->
<section id="membership" class="py-20 bg-green-900 text-white text-center">
  <div class="max-w-4xl mx-auto px-6 space-y-6">

    <h2 class="text-4xl font-bold">Become a Member</h2>

    <p class="text-white/80">
      Join SLDC and enjoy financial benefits, protection programs, and cooperative growth opportunities.
    </p>

    <a href={`${base}membership`}
       class="inline-block bg-white text-green-900 px-6 py-3 rounded-xl font-semibold">
      Start Membership
    </a>

  </div>
</section>

<!-- LOAN CALCULATOR PREVIEW -->
<section id="loan-calculator" class="py-20 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6 text-center space-y-6">

    <h2 class="text-4xl font-bold">Loan Calculator</h2>

    <p class="text-slate-600 max-w-3xl mx-auto leading-relaxed">
      Calculate the net proceeds of first timers or those with no existing loans quickly and easily using our built-in calculator.
    </p>

    <div class="grid md:grid-cols-2 gap-6 text-left mt-10">

      <div class="bg-white p-6 rounded-2xl shadow-md">
        <h3 class="font-semibold text-xl mb-2">Fast Computation</h3>
        <p class="text-slate-600 text-sm">
          Get net proceeds instantly for various loan types.
        </p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow-md">
        <h3 class="font-semibold text-xl mb-2">Net Proceeds</h3>
        <p class="text-slate-600 text-sm">
          See real loan take-home amount after interest and deductions.
        </p>
      </div>

    </div>

    <a
      href={`${base}loancalculator`}
      class="inline-block mt-10 bg-green-700 hover:bg-green-600 text-white px-6 py-3 rounded-xl font-semibold"
    >
      Open Loan Calculator →
    </a>

  </div>
</section>

<!-- CONTACT PREVIEW -->
<section id="contact" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6 text-center space-y-6">

    <h2 class="text-4xl font-bold">Contact Us</h2>

    <p class="text-slate-600">
      Have questions? We're here to help.
    </p>

    <a href={`${base}contact`} class="text-blue-600 hover:underline">
      View Contact Details →
    </a>

  </div>
</section>

</BaseLayout>
