---
import bodandcom1 from '../assets/bodandcom1.jpg';
import bodandcom2 from '../assets/bodandcom2.jpg';
import bodandcom3 from '../assets/bodandcom3.jpg';
import bodandcom4 from '../assets/bodandcom4.jpg';
import orgchart from '../assets/orgchart.png';
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <div class="max-w-6xl mx-auto px-6 py-16 space-y-16">

    <!-- HERO TITLE -->
    <section class="text-center space-y-4">
      <h1 class="text-5xl font-bold tracking-tight text-slate-900">
        About San Luis Development Cooperative
      </h1>
      <p class="text-slate-500">
        Lucban, Quezon
      </p>
    </section>

    <!-- MISYON -->
    <section class="grid md:grid-cols-3 gap-8 items-center">
      <div class="md:col-span-1">
        <div class="relative" style="z-index: 0; display: inline-block; min-width: max-content;">
          <div style="border-radius: 8px 0 0 8px; overflow: hidden; position: absolute; inset: 0; filter: drop-shadow(0 2px 2px rgba(0,0,0,0.15));">
            <div style="width: 100%; height: 100%; clip-path: polygon(0 0, 100% 0, 95% 50%, 100% 100%, 0 100%); background: linear-gradient(to right, #14532d, #15803d);">
            </div>
          </div>
          <div class="relative px-3 py-2" style="z-index: 1;">
            <h2 class="text-3xl font-semibold text-white">MISYON</h2>
            <p class="text-sm text-green-200">San Luis Development Cooperative</p>
          </div>
        </div>
      </div>

      <div class="md:col-span-2 bg-white rounded-2xl shadow-md p-8 hover:shadow-lg transition">
        <div class="space-y-3 text-slate-700 leading-relaxed">
          <p><span class="font-semibold">KASAPIAN</span> - Masigasig na tumatangkililk sa mga serbisyo ng Kooperatiba.</p>
          <p><span class="font-semibold">PAMUNUAN</span> - Naglilingkod nang may kahusayan at dedikasyon.</p>
          <p><span class="font-semibold">PANGASIWAAN</span> - Nagmamalasakit sa pamamahala nang may kasanayan at kaalaman sa kooperatiba.</p>
          <p><span class="font-semibold">PAMAYANAN</span> - Nakikiisa at sumusuporta sa lahat ng programang pangkaunlaran ng Kooperatiba.</p>
        </div>
      </div>
    </section>

    <!-- ADHIKAIN -->
    <section class="grid md:grid-cols-3 gap-8 items-center bg-gradient-to-r from-green-900 to-green-700 text-white rounded-2xl p-10 shadow-lg">
      
      <div class="md:col-span-2 space-y-4">
        <p class="text-lg leading-relaxed">
          "Naninindigan sa paglilingkod para sa kabuuang pag-unlad ng mga kasapi at pamayanan"
        </p>
      </div>

      <div class="md:col-span-1">
        <h2 class="text-3xl font-semibold mb-2">ADHIKAIN</h2>
        <p class="text-sm opacity-80">San Luis Development Cooperative</p>
        <p class="text-sm opacity-70">Lucban, Quezon</p>
      </div>

    </section>

    <!-- PANANAW -->
    <section class="grid md:grid-cols-3 gap-8 items-center">

      <div class="md:col-span-2">
        <div class="relative" style="z-index: 0; display: inline-block; min-width: max-content;filter: drop-shadow(0 2px 2px rgba(0,0,0,0.15));">
          <div style="border-radius: 8px 0 0 8px; overflow: hidden; position: absolute; inset: 0;">
            <div style="width: 100%; height: 100%; clip-path: polygon(0 0, 100% 0, 95% 50%, 100% 100%, 0 100%); background: linear-gradient(to right, #14532d, #15803d);">
            </div>
          </div>
          <div class="relative px-3 py-2" style="z-index: 1;">
            <h2 class="text-3xl font-semibold text-white">PANANAW</h2>
            <p class="text-sm text-green-200">San Luis Development Cooperative</p>
          </div>
        </div>
      </div>

      <div class="md:col-span-1 bg-slate-50 rounded-2xl p-6 shadow-sm">
        <p class="text-slate-700 italic">
          "Isang nangungunang Kooperatiba sa Timog Katagalugan"
        </p>
      </div>

    </section>

    <!-- HISTORY -->
    <section class="bg-white rounded-2xl shadow-md overflow-hidden">

      <div class="bg-green-900 text-white text-center py-10">
        <h2 class="text-3xl font-bold">
          History of San Luis Development Cooperative
        </h2>
      </div>

      <div class="p-6 md:p-10">
        <div class="max-w-4xl mx-auto rounded-2xl overflow-hidden shadow-lg">
          <iframe
            class="w-full aspect-video"
            src="https://www.youtube.com/embed/-GtoB0VU96E"
            title="History Video"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>
      </div>

    </section>

  <!-- BOD and Committees -->
  <section class="bg-white rounded-2xl shadow-md overflow-hidden">

    <div class="bg-green-900 text-white text-center py-10">
      <h2 class="text-3xl font-bold">
        Board of Directors and Committees
      </h2>
    </div>

    <div class="p-6 md:p-10">
      <div class="max-w-5xl mx-auto grid sm:grid-cols-2 gap-6">

        <img
          src={bodandcom1.src}
          alt="BOD and Committee 1"
          class="w-full h-auto rounded-xl shadow-md object-cover"
        />

        <img
          src={bodandcom2.src}
          alt="BOD and Committee 2"
          class="w-full h-auto rounded-xl shadow-md object-cover"
        />

        <img
          src={bodandcom3.src}
          alt="BOD and Committee 3"
          class="w-full h-auto rounded-xl shadow-md object-cover"
        />

        <img
          src={bodandcom4.src}
          alt="BOD and Committee 4"
          class="w-full h-auto rounded-xl shadow-md object-cover"
        />

      </div>
    </div>

  </section>

  <!-- Organizational Chart -->
  <section class="bg-white rounded-2xl shadow-md overflow-hidden">

    <div class="bg-green-900 text-white text-center py-10">
      <h2 class="text-3xl font-bold">
        Organizational Chart
      </h2>
    </div>

    <div class="p-6 md:p-10">
      <div class="max-w-5xl mx-auto">

        <img
          src={orgchart.src}
          alt="Organizational Chart"
          class="w-full h-auto rounded-xl shadow-md object-cover"
        />
      </div>
    </div>

  </section>

  <section class="bg-slate-50 rounded-2xl shadow-lg p-10">
    <h2 class="text-3xl font-bold mb-8 text-center">
      Annual Reports
    </h2>

    <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">


    <!-- 2026 (Latest) -->
    <div class="bg-white rounded-xl shadow-md p-6 text-center border-2 border-green-800">
      <span class="text-xs bg-green-800 text-white px-3 py-1 rounded-full">
        Latest
      </span>
      <h3 class="text-2xl font-semibold mt-3 mb-2">2026</h3>
      <p class="text-sm text-slate-500 mb-4">Annual Report</p>

      <a href={`${base}reports/annual-report-2026.pdf`}
        target="_blank"
        class="inline-block bg-green-900 hover:bg-green-800 text-white font-semibold px-6 py-2 rounded-lg transition">
        View Report
      </a>
    </div>

    <!-- 2025 -->
    <div class="bg-white rounded-xl shadow-md p-6 text-center">
      <h3 class="text-2xl font-semibold mt-3 mb-2">2025</h3>
      <p class="text-sm text-slate-500 mb-4">Annual Report</p>

      <a href={`${base}reports/annual-report-2025.pdf`}
        target="_blank"
        class="inline-block bg-green-700 hover:bg-green-600 text-white font-semibold px-6 py-2 rounded-lg transition">
        View Report
      </a>
    </div>

    </div>
  </section>
  
  </div>

</BaseLayout>



